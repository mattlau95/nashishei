# Production / staging API base URL.
# In dev this is unset and the Vite proxy forwards /api → localhost:8080.
# In the bundled Tauri app there is no proxy, so set this to the live server URL.
VITE_API_BASE=https://api.nashishei.example.com

# ML sidecar base URL.
# In dev, set to /ml-sidecar so the Vite proxy forwards to docker compose ml (port 8000).
# Leave unset in production; the Tauri invoke command provides the sidecar URL instead.
VITE_ML_BASE=/ml-sidecar
